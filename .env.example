# OpenCash — Environment Variables

# Required: Solana private key (base58) for the fee payer wallet
# This wallet needs SOL for transaction fees
SVM_PRIVATE_KEY=

# Required: Solana address to receive payments
PAYMENT_RECIPIENT_ADDRESS=

# Optional: RPC URL (defaults to public mainnet)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: External facilitator URL (if not using built-in)
# FACILITATOR_URL=https://facilitator.corbits.dev

# Optional: Server port (default: 4020)
# PORT=4020

# Optional: Path to config file (default: ./opencash.config.yaml)
# OPENCASH_CONFIG=./opencash.config.yaml

# ── Upstream API Keys (only needed for services you configure) ──

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# SERPER_API_KEY=...
