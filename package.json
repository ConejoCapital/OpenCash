{
  "name": "opencash",
  "version": "0.1.0",
  "description": "Open-source universal x402 API proxy — gate any upstream API behind stablecoin micropayments on Solana",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "postinstall": "node scripts/patch-token2022.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "x402",
    "solana",
    "usdc",
    "pyusd",
    "payments",
    "api-proxy",
    "micropayments",
    "stablecoin"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ConejoCapital/OpenCash"
  },
  "dependencies": {
    "@faremeter/facilitator": "^0.17.1",
    "@faremeter/middleware": "^0.17.1",
    "@faremeter/payment-solana": "^0.17.1",
    "@faremeter/types": "^0.17.1",
    "@hono/node-server": "^1.19.11",
    "@scure/base": "^2.0.0",
    "@solana/spl-token": "^0.4.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@solana/kit": "^2.1.0",
    "@solana/web3.js": "^1.98.0",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
